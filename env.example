# ==================== 数据库配置 ====================
# 优先使用 DATABASE_URL 连接字符串（适用于远程数据库）
# 格式: postgresql://user:password@host:port/dbname
# DATABASE_URL=
# 未设置 DATABASE_URL 时回退到以下独立字段拼接
DB_HOST=localhost
DB_PORT=5432
DB_USER=gateway
DB_PASSWORD=dev_password
DB_NAME=gateway
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
# NEED_RESET_DATABASE=false        # 是否强制重置数据库表（危险操作，仅用于开发）

# ==================== 支付渠道控制 ====================
# 逗号分隔，可选值: stripe, alipay, wechatpay
ALLOWED_PROVIDERS=stripe

# ==================== Stripe 配置（必填） ====================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ==================== 支付宝配置（可选） ====================
# ALIPAY_APP_ID=your_alipay_app_id_here
# ALIPAY_PRIVATE_KEY=...           # 应用私钥内容
# ALIPAY_PUBLIC_KEY=...            # 支付宝公钥内容
# ALIPAY_SANDBOX=false

# ==================== 微信支付配置（可选） ====================
# WECHATPAY_MCHID=your_mchid_here
# WECHATPAY_APPID=your_appid_here
# WECHATPAY_API_V3_KEY=your_api_v3_key_here
# WECHATPAY_SERIAL_NO=your_serial_no_here
# WECHATPAY_PRIVATE_KEY_PATH=/path/to/apiclient_key.pem

# ==================== 应用配置 ====================
# DEBUG=false                      # 调试模式（生产环境勿开启）
LOG_LEVEL=INFO
# PAYMENT_EXPIRE_MINUTES_DEFAULT=30  # 支付过期时间（分钟，1~1440）

# ==================== Worker 配置 ====================
# WORKER_POLL_INTERVAL=5           # 轮询间隔（秒）
# WORKER_BATCH_SIZE=10             # 每批处理任务数
# WORKER_MAX_RETRIES=10            # 最大重试次数
