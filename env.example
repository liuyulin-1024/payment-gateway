# ==================== 数据库配置 ====================
# 优先使用 DATABASE_URL 连接字符串（适用于远程数据库）
# 格式: postgresql://user:password@host:port/dbname
# DATABASE_URL=
# 未设置 DATABASE_URL 时回退到以下独立字段拼接
DB_HOST=localhost
DB_PORT=5432
DB_USER=gateway
DB_PASSWORD=dev_password
DB_NAME=gateway
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
# DB_POOL_RECYCLE=1800              # 连接最大存活秒数（防止被中间件/防火墙断开）
# NEED_RESET_DATABASE=false        # 是否强制重置数据库表（危险操作，仅用于开发）

# ==================== 支付渠道控制 ====================
# 逗号分隔，可选值: stripe
ALLOWED_PROVIDERS=stripe

# ==================== Stripe 配置（必填） ====================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ==================== 应用配置 ====================
# DEBUG=false                      # 调试模式（生产环境勿开启）
LOG_LEVEL=INFO
# PAYMENT_EXPIRE_MINUTES_DEFAULT=30  # 支付过期时间（分钟，1~1440）

# ==================== Worker 配置 ====================
# WORKER_POLL_INTERVAL=5           # 轮询间隔（秒）
# WORKER_BATCH_SIZE=10             # 每批处理任务数
# WORKER_MAX_RETRIES=10            # 最大重试次数
# WORKER_CONCURRENCY=5             # 单批内并发投递数

# ==================== 订阅配置 ====================
# SUBSCRIPTION_CHECKOUT_EXPIRE_MINUTES=60           # 订阅 Checkout Session 过期时间（分钟，30~1440）
# SUBSCRIPTION_SINGLE_ACTIVE=true                   # 是否限制每用户单活跃订阅（默认 true）
# SUBSCRIPTION_INCOMPLETE_CLEANUP_MINUTES=120       # 过期 incomplete 订阅清理阈值（分钟，60~2880）
# SUBSCRIPTION_CLEANUP_INTERVAL=300                 # Worker 清理任务执行间隔（秒，默认 300）
